  "faqs": [
    {
      "id": "1",
      "category": "general",
      "question": "What is DentalMall.ge?",
      "answer": "DentalMall.ge is an online platform that connects dental clinics with suppliers. Here you can search, compare, and order dental materials quickly and easily."
    },
    {
      "id": "2",
      "category": "general",
      "question": "Who is the platform for?",
      "answer": "The platform is designed for:\n• Dental clinics\n• Doctors\n• Dental supply vendors"
    },
    {
      "id": "3",
      "category": "general",
      "question": "How do I purchase a product?",
      "answer": "1. Register an account\n2. Find the product you need\n3. Add it to your cart\n4. Confirm your order"
    },
    {
      "id": "4",
      "category": "general",
      "question": "Can I combine products from different suppliers in one order?",
      "answer": "Yes — DentalMall.ge lets you add products from multiple suppliers to a single cart."
    },
    {
      "id": "5",
      "category": "general",
      "question": "How do I see product details?",
      "answer": "On every product page you'll find full information: description, price, manufacturer, and availability."
    },
    {
      "id": "6",
      "category": "general",
      "question": "How does delivery work?",
      "answer": "Delivery is handled by our courier service, directly to your address."
    },
    {
      "id": "7",
      "category": "general",
      "question": "How long does delivery take?",
      "answer": "Usually the next business day.\nFor pre-orders, delivery time depends on the supplier partner."
    },
    {
      "id": "8",
      "category": "general",
      "question": "Is there a delivery fee?",
      "answer": "Delivery cost may vary depending on location and order size."
    },
    {
      "id": "9",
      "category": "general",
      "question": "What payment methods are available?",
      "answer": "• Online payment (card)\n• Cash on delivery\n• Bank transfer"
    },
    {
      "id": "10",
      "category": "general",
      "question": "Is payment secure?",
      "answer": "Yes — every transaction is protected by modern security standards."
    },
    {
      "id": "11",
      "category": "suppliers",
      "question": "How do I register as a supplier?",
      "answer": "Sign up on the platform and fill out the supplier form. Our team will contact you to confirm the details."
    },
    {
      "id": "12",
      "category": "suppliers",
      "question": "What benefits do I get by listing on DentalMall.ge?",
      "answer": "• Increased sales\n• Access to a wider audience\n• Easy order management"
    },
    {
      "id": "13",
      "category": "suppliers",
      "question": "Can products be returned?",
      "answer": "Yes — returns are accepted under certain conditions (undamaged product, original packaging, etc.)."
    },
    {
      "id": "14",
      "category": "suppliers",
      "question": "What should I do if there's a problem?",
      "answer": "Contact our support team and we'll help resolve the issue quickly."
    },
    {
      "id": "15",
      "category": "suppliers",
      "question": "How can I contact you?",
      "answer": "You can reach us by:\n• Email\n• Phone"
    },
    {
      "id": "16",
      "category": "suppliers",
      "question": "What are the support team's working hours?",
      "answer": "Monday through Friday, 10:00 – 18:00"
    }
  ],
